{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "cpa-verify.html", "use": "@vercel/static" },
    { "src": "docs/**", "use": "@vercel/static" },
    { "src": "api/intake.js", "use": "@vercel/node" },
    { "src": "api/cpa.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/intake", "dest": "/api/intake.js" },
    { "src": "/api/cpa", "dest": "/api/cpa.js" },
    { "src": "/cpa-verify", "dest": "/cpa-verify.html" },
    { "src": "/docs/(.*)", "dest": "/docs/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
